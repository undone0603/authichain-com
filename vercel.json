{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://authichain.com" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, PATCH, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, x-api-key" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/demo", "destination": "/demo.html" },
    { "source": "/verify", "destination": "/verify.html" },
    { "source": "/marketplace", "destination": "/marketplace.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/sdk", "destination": "/sdk.html" },
    { "source": "/", "destination": "/index.html" }
  ],
  "routes": [
    { "src": "/404", "dest": "/404.html", "status": 404 },
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/404.html", "status": 404 }
  ]
}
